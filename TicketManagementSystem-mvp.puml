@startuml
left to right direction

actor "Пользователь" as User
actor "Сотрудник поддержки" as Support
actor "Администратор" as Admin

rectangle "Система обработки обращений (MVP)" {

  User -- (Зарегистрироваться)
  User -- (Аутентификация)
  User -- (Создать тикет)
  User -- (Просмотреть свои тикеты)
  User -- (Редактировать свой тикет)
  User -- (Удалить свой тикет)
  User -- (Добавить комментарий к своему тикету)
  User -- (Настроить каналы уведомлений)

  Support -- (Аутентификация)
  Support -- (Просмотреть тикеты своей категории)
  Support -- (Просмотреть назначенные на него тикеты)
  Support -- (Взять тикет в работу)
  Support -- (Изменить статус назначенного тикета)
  Support -- (Добавить комментарий к назначенному тикету)
  Support -- (Закрыть назначенный тикет)

  Admin -- (Аутентификация)
  Admin -- (Создать тему)
  Admin -- (Редактировать тему)
  Admin -- (Создать категорию)
  Admin -- (Назначить сотрудников категории)
  Admin -- (Зарегистрировать сотрудника поддержки)
  Admin -- (Просмотреть тикеты категории)
  Admin -- (Просмотреть статистику)
  Admin -- (Переназначить исполнителя)
  Admin -- (Изменить статус любого тикета)

  (Создать тикет) ..> (Присвоить категорию) : <<include>>
  (Создать категорию) ..> (Привязать к теме) : <<include>>

  (Взять тикет в работу) ..> (Назначить исполнителя) : <<include>>
  (Изменить статус назначенного тикета) ..> (Отправить уведомление) : <<include>>
  (Изменить статус любого тикета) ..> (Отправить уведомление) : <<include>>
  (Добавить комментарий к назначенному тикету) ..> (Отправить уведомление) : <<include>>
}

@enduml